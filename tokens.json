{
  "$schema": "https://schemas.tokens.studio/latest/tokens-schema.json",
  "name": "Patrimonium Design System",
  "version": "2.0.1",
  "description": "Tokens oficiais do Patrimonium DS. Compatível com Style Dictionary e Tokens Studio for Figma.",

  "color": {
    "brand": {
      "blue": {
        "value": "#1A3375",
        "type": "color",
        "description": "Patrimonium Blue · primária absoluta. Headlines, botões padrão, links, ícones institucionais."
      },
      "green": {
        "value": "#00FCA8",
        "type": "color",
        "description": "Patrimonium Green · acento. P-cápsula, affirmative, status 'ativo/positivo'. Nunca como texto sobre branco."
      },
      "white": {
        "value": "#FFFFFF",
        "type": "color",
        "description": "Branco · fundo principal do produto."
      },
      "navy-deep": {
        "value": "#0B1B3F",
        "type": "color",
        "description": "Navy escuríssimo · fundo invertido, dark mode, hero. Usar no lugar de preto."
      },
      "navy-soft": {
        "value": "#3059AF",
        "type": "color",
        "description": "Navy médio · raro."
      },
      "teal": {
        "value": "#0C998F",
        "type": "color",
        "description": "Teal · data viz, accents secundários."
      },
      "cyan": {
        "value": "#1AFFFF",
        "type": "color",
        "description": "Ciano luminoso · raro."
      },
      "neutral-dark": {
        "value": "#3D3D3D",
        "type": "color",
        "description": "Neutro escuro de marca · texto corpo."
      }
    },

    "neutral": {
      "surface": {
        "value": "#F7F8FB",
        "type": "color",
        "description": "Fundo de página, app shell, header de tabela."
      },
      "light": {
        "value": "#C8C8CC",
        "type": "color",
        "description": "Borders, dividers, disabled fill, placeholders, dias adjacentes em calendar."
      },
      "strong": {
        "value": "#3D3D3D",
        "type": "color",
        "description": "Texto corpo, ícones, labels."
      }
    },

    "state": {
      "success": {
        "value": "#1F8F5C",
        "type": "color",
        "description": "Confirmação, recuperação aprovada, status positivo. Verde text-safe sobre branco."
      },
      "success-bg": {
        "value": "#E6F7EF",
        "type": "color",
        "description": "Fundo claro de alerts/banners success."
      },
      "warning": {
        "value": "#F5A623",
        "type": "color",
        "description": "Aviso, vencimento próximo."
      },
      "warning-bg": {
        "value": "#FEF3C7",
        "type": "color",
        "description": "Fundo claro de alerts/banners warning."
      },
      "danger": {
        "value": "#B91C1C",
        "type": "color",
        "description": "Erro, ação destrutiva, falha."
      },
      "danger-strong": {
        "value": "#871414",
        "type": "color",
        "description": "Texto sobre danger-bg (contraste reforçado)."
      },
      "danger-bg": {
        "value": "#FEE2E2",
        "type": "color",
        "description": "Fundo claro de alerts/banners danger."
      },
      "info": {
        "value": "#1A3375",
        "type": "color",
        "description": "Informativo (reusa brand-blue)."
      },
      "info-bg": {
        "value": "#E0E7FF",
        "type": "color",
        "description": "Fundo claro de alerts info, selected state em tabela, range highlight em calendar."
      },
      "neutral": {
        "value": "#475569",
        "type": "color",
        "description": "Sem ação, arquivado, indisponível."
      },
      "neutral-bg": {
        "value": "#EEF2F6",
        "type": "color",
        "description": "Fundo claro de status neutro."
      },
      "pending": {
        "value": "#3730A3",
        "type": "color",
        "description": "Em fila, aguardando processamento."
      },
      "pending-bg": {
        "value": "#E0E7FF",
        "type": "color",
        "description": "Fundo claro de status pending."
      },

      "success-dark": {
        "value": "#4FCB87",
        "type": "color",
        "description": "Versão clareada de success para dark mode. Serve como borda, ícone, dot, badge. Texto sobre success-bg-dark deve ser branco."
      },
      "success-bg-dark": {
        "value": "#1A6E48",
        "type": "color",
        "description": "Fundo escuro de alerts/banners success em dark mode. Texto branco em cima (AA)."
      },
      "warning-dark": {
        "value": "#FFB84D",
        "type": "color",
        "description": "Versão clareada de warning para dark mode. Borda, ícone, dot."
      },
      "warning-bg-dark": {
        "value": "#8C5A0F",
        "type": "color",
        "description": "Fundo escuro de alerts/banners warning em dark mode. Texto branco em cima (AA)."
      },
      "danger-dark": {
        "value": "#F08080",
        "type": "color",
        "description": "Versão clareada de danger para dark mode. Borda, ícone, dot."
      },
      "danger-bg-dark": {
        "value": "#8B2828",
        "type": "color",
        "description": "Fundo escuro de alerts/banners danger em dark mode. Texto branco em cima (AAA)."
      },
      "info-dark": {
        "value": "#95ADE3",
        "type": "color",
        "description": "Versão clareada de info para dark mode. Borda, ícone, dot."
      },
      "info-bg-dark": {
        "value": "#2A4FA0",
        "type": "color",
        "description": "Fundo escuro de alerts/banners info em dark mode. Texto branco em cima (AAA)."
      },
      "neutral-dark": {
        "value": "#8A95A8",
        "type": "color",
        "description": "Versão clareada de neutral para dark mode. Borda, ícone, dot."
      },
      "neutral-bg-dark": {
        "value": "#3B4555",
        "type": "color",
        "description": "Fundo escuro de status neutro em dark mode. Texto branco em cima (AAA)."
      },
      "pending-dark": {
        "value": "#A99DEC",
        "type": "color",
        "description": "Versão clareada de pending para dark mode. Borda, ícone, dot."
      },
      "pending-bg-dark": {
        "value": "#4A3DA0",
        "type": "color",
        "description": "Fundo escuro de status pending em dark mode. Texto branco em cima (AAA)."
      }
    },

    "foreground": {
      "primary": {
        "value": "{color.brand.navy-deep}",
        "type": "color",
        "description": "Headings sobre fundo claro."
      },
      "body": {
        "value": "{color.neutral.strong}",
        "type": "color",
        "description": "Texto de corpo."
      },
      "secondary": {
        "value": "{color.neutral.light}",
        "type": "color",
        "description": "Texto secundário, metadados."
      },
      "on-brand": {
        "value": "#FFFFFF",
        "type": "color",
        "description": "Texto sobre brand-blue ou brand-navy-deep."
      },
      "link": {
        "value": "{color.brand.blue}",
        "type": "color",
        "description": "Links em texto corrido."
      }
    },

    "overlay": {
      "backdrop-modal": {
        "value": "rgba(15, 23, 42, 0.45)",
        "type": "color",
        "description": "Fundo escurecido atrás de modal/drawer."
      },
      "menu-hover-on-light": {
        "value": "rgba(26, 51, 117, 0.06)",
        "type": "color",
        "description": "Hover de row em tabela ou item de menu sobre fundo claro."
      },
      "menu-hover-on-dark": {
        "value": "rgba(255, 255, 255, 0.08)",
        "type": "color",
        "description": "Hover de item em sidebar/topbar invertido."
      },
      "menu-active-on-dark": {
        "value": "rgba(255, 255, 255, 0.12)",
        "type": "color",
        "description": "Item ativo em sidebar/topbar invertido."
      }
    }
  },

  "typography": {
    "family": {
      "sans": {
        "value": "'RNS Sanz', 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
        "type": "fontFamily",
        "description": "Família principal de UI e display."
      },
      "mono": {
        "value": "ui-monospace, 'SF Mono', Menlo, Consolas, monospace",
        "type": "fontFamily",
        "description": "Monoespaçada para CNPJ, valores tabulares, identificadores. Sempre com tabular-nums."
      }
    },

    "display": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "56px",
        "fontWeight": 800,
        "lineHeight": 1.1,
        "letterSpacing": "-0.02em"
      },
      "type": "typography",
      "description": "Voz da marca em volume máximo. Hero, landing, capas. NÃO usar dentro do produto."
    },
    "h1": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "40px",
        "fontWeight": 700,
        "lineHeight": 1.1,
        "letterSpacing": "-0.01em"
      },
      "type": "typography",
      "description": "Único H1 por tela. Headers principais."
    },
    "h2": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "32px",
        "fontWeight": 700,
        "lineHeight": 1.25,
        "letterSpacing": "-0.01em"
      },
      "type": "typography",
      "description": "Subtítulos de seção."
    },
    "h3": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "24px",
        "fontWeight": 600,
        "lineHeight": 1.25,
        "letterSpacing": "0"
      },
      "type": "typography",
      "description": "Títulos de card, modal, drawer."
    },
    "h4": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "20px",
        "fontWeight": 500,
        "lineHeight": 1.4,
        "letterSpacing": "0"
      },
      "type": "typography",
      "description": "Sub-cabeçalhos de empty state."
    },
    "body-lg": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "18px",
        "fontWeight": 400,
        "lineHeight": 1.5
      },
      "type": "typography",
      "description": "Texto principal de empty state, descrições importantes."
    },
    "body": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "16px",
        "fontWeight": 400,
        "lineHeight": 1.5
      },
      "type": "typography",
      "description": "Texto padrão de UI, botão md."
    },
    "body-sm": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "14px",
        "fontWeight": 400,
        "lineHeight": 1.5
      },
      "type": "typography",
      "description": "Texto secundário, body de table, descrições."
    },
    "eyebrow": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "12px",
        "fontWeight": 700,
        "lineHeight": 1.2,
        "letterSpacing": "0.12em",
        "textTransform": "uppercase"
      },
      "type": "typography",
      "description": "Sobrelinha acima de seção, label de tabela. CAIXA ALTA."
    },
    "caption": {
      "value": {
        "fontFamily": "{typography.family.sans}",
        "fontSize": "12px",
        "fontWeight": 600,
        "lineHeight": 1.3,
        "letterSpacing": "0.02em",
        "textTransform": "uppercase"
      },
      "type": "typography",
      "description": "Legenda, metadado, timestamp. CAIXA ALTA."
    }
  },

  "spacing": {
    "0":  { "value": "0",    "type": "spacing", "description": "Zero." },
    "1":  { "value": "4px",  "type": "spacing", "description": "Preferencial. Gap interno mínimo." },
    "2":  { "value": "8px",  "type": "spacing", "description": "Preferencial. Gap padrão entre elementos próximos." },
    "3":  { "value": "12px", "type": "spacing", "description": "Exceção. Gaps internos finos." },
    "4":  { "value": "16px", "type": "spacing", "description": "Preferencial. Padding de componentes pequenos." },
    "5":  { "value": "20px", "type": "spacing", "description": "Raro · evitar." },
    "6":  { "value": "24px", "type": "spacing", "description": "Preferencial. Padding de cards e modais." },
    "7":  { "value": "32px", "type": "spacing", "description": "Preferencial. Gap entre seções." },
    "8":  { "value": "40px", "type": "spacing", "description": "Raro · evitar." },
    "9":  { "value": "48px", "type": "spacing", "description": "Exceção. Separação ampla." },
    "10": { "value": "64px", "type": "spacing", "description": "Preferencial. Separação grande entre blocos." },
    "11": { "value": "80px", "type": "spacing", "description": "Exceção. Hero, landing." }
  },

  "radius": {
    "mini": {
      "value": "4px",
      "type": "borderRadius",
      "description": "Exceção. Apenas mini-controles (≤ 20px), ex: checkbox indicator."
    },
    "sm": {
      "value": "8px",
      "type": "borderRadius",
      "description": "Embalagens pequenas: chips, inputs, badges, botões gerais, tooltips."
    },
    "md": {
      "value": "16px",
      "type": "borderRadius",
      "description": "Containers padrão: cards, modais, painéis, drop zones."
    },
    "lg": {
      "value": "32px",
      "type": "borderRadius",
      "description": "Containers grandes: hero, sheets, banners institucionais."
    },
    "pill": {
      "value": "999px",
      "type": "borderRadius",
      "description": "Identidade e ação: botão affirmative, dots, logo, status circular, switch track."
    }
  },

  "shadow": {
    "1": {
      "value": "0 1px 2px rgba(15, 23, 42, 0.04)",
      "type": "boxShadow",
      "description": "Repouso · cards default, divisórias sutis."
    },
    "2": {
      "value": "0 1px 2px rgba(15, 23, 42, 0.06), 0 4px 12px rgba(15, 23, 42, 0.08)",
      "type": "boxShadow",
      "description": "Hover · dropdown, tooltip, popover."
    },
    "3": {
      "value": "0 4px 8px rgba(15, 23, 42, 0.08), 0 16px 40px rgba(15, 23, 42, 0.12)",
      "type": "boxShadow",
      "description": "Modal · drawer, sheet, overlay."
    },
    "focus-ring": {
      "value": "0 0 0 4px rgba(26, 51, 117, 0.18)",
      "type": "boxShadow",
      "description": "Anel de foco · navy 18% alpha, 4px spread."
    }
  },

  "border": {
    "1": {
      "value": "1px solid {color.neutral.light}",
      "type": "border",
      "description": "Border padrão."
    },
    "2": {
      "value": "1.5px solid {color.neutral.light}",
      "type": "border",
      "description": "Border médio. Coincide com stroke Lucide 1.5px."
    },
    "strong": {
      "value": "1px solid {color.brand.blue}",
      "type": "border",
      "description": "Border destacado em estado de foco."
    }
  },

  "motion": {
    "duration": {
      "instant": { "value": "0ms",   "type": "duration", "description": "Focus ring, mudança lógica imediata." },
      "fast":    { "value": "120ms", "type": "duration", "description": "Active state, micro-feedback de clique." },
      "base":    { "value": "200ms", "type": "duration", "description": "Hover, transições padrão." },
      "moderate":{ "value": "250ms", "type": "duration", "description": "Tooltip, dropdown, popover." },
      "slow":    { "value": "320ms", "type": "duration", "description": "Modal, drawer, sheet." }
    },
    "easing": {
      "out": {
        "value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "type": "cubicBezier",
        "description": "Movimentos que terminam (entrada de elementos)."
      },
      "std": {
        "value": "cubic-bezier(0.4, 0, 0.2, 1)",
        "type": "cubicBezier",
        "description": "Movimentos contínuos (loops, sliders)."
      },
      "linear": {
        "value": "linear",
        "type": "cubicBezier",
        "description": "Apenas progress bars determinadas."
      }
    }
  },

  "layout": {
    "container-max": {
      "value": "1280px",
      "type": "sizing",
      "description": "Largura máxima do container principal."
    },
    "content-max": {
      "value": "880px",
      "type": "sizing",
      "description": "Largura máxima de conteúdo de leitura."
    },
    "icon-stroke": {
      "value": "1.5px",
      "type": "borderWidth",
      "description": "Stroke uniforme de ícones Lucide em todos os tamanhos."
    }
  },

  "icon": {
    "size": {
      "sm": { "value": "16px", "type": "sizing", "description": "Chips, inputs pequenos, badges." },
      "md": { "value": "20px", "type": "sizing", "description": "Default · botões, inputs, ao lado de texto." },
      "lg": { "value": "24px", "type": "sizing", "description": "Menu lateral, topbar, navegação." },
      "xl": { "value": "32px", "type": "sizing", "description": "Empty states, hero, ilustrações." }
    }
  },

  "breakpoint": {
    "sm":  { "value": "640px",  "type": "sizing", "description": "Tablet pequeno." },
    "md":  { "value": "768px",  "type": "sizing", "description": "Tablet." },
    "lg":  { "value": "1024px", "type": "sizing", "description": "Desktop pequeno." },
    "xl":  { "value": "1280px", "type": "sizing", "description": "Desktop padrão." },
    "2xl": { "value": "1536px", "type": "sizing", "description": "Desktop grande." }
  },

  "gradient": {
    "hero": {
      "value": "linear-gradient(135deg, #0B1B3F 0%, #1A3375 100%)",
      "type": "color",
      "description": "Hero gradient (dark) · linear 135° navy-deep → brand-blue. Hero institucional dark, capa de relatório, login. Para hero em light mode usar gradient.soft-hero."
    },
    "soft-hero": {
      "value": "linear-gradient(135deg, #F7F8FB 0%, #E0E7FF 100%)",
      "type": "color",
      "description": "Soft hero (light) · novo na v2.0.1. Banner institucional em light mode, hero de página de produto, faixa decorativa em landing light. Para container largo (banner/faixa), não card pequeno."
    },
    "brand-accent": {
      "value": "linear-gradient(135deg, #1A3375 0%, #00FCA8 100%)",
      "type": "color",
      "description": "Brand accent · linear 135° brand-blue → brand-green. KPI institucional via background-clip:text, fundo de KPI card destaque, ícone de hero (48-96px), key visual em campanha, CTA destaque. Restrição apenas técnica: ícone 48-96px, texto ≥40px, fundo card ≥120px. Restrição de 'uma ocorrência por tela' (v2.0.0) foi REMOVIDA na v2.0.1."
    },
    "accent-soft": {
      "value": "linear-gradient(135deg, #E0E7FF 0%, #E6F7EF 100%)",
      "type": "color",
      "description": "Accent soft (light) · novo na v2.0.1. Equivalente 'diet' do brand-accent para light. Fundo de card destacado, banner de feature nova, callout, banner 'Beta/Novo'. Sutil, identitário, light-mode-first."
    },
    "data-accent": {
      "value": "linear-gradient(135deg, #1A3375 0%, #0C998F 100%)",
      "type": "color",
      "description": "Data accent · linear 135° brand-blue → teal. Barras de gráfico, área de chart, ícone de categoria temática, painel onde brand-green seria demais."
    }
  },

  "glass": {
    "dark": {
      "value": {
        "backdrop-filter": "blur(20px)",
        "background": "rgba(11, 27, 63, 0.72)",
        "border": "0.5px solid rgba(255, 255, 255, 0.10)",
        "box-shadow": "0 4px 8px rgba(15, 23, 42, 0.08), 0 16px 40px rgba(15, 23, 42, 0.12)",
        "fallback-background": "#1A3375",
        "fallback-border": "0.5px solid #3059AF"
      },
      "type": "other",
      "description": "Glass dark · uso sobre fundos escuros (dark mode, banner com hero gradient, hero dark). Regra-mãe: containers estruturais (sidebar, banner, KPI cards limpos, cards de destaque). NÃO usar em containers densos em texto (tabela, card de detalhe longo)."
    },
    "light": {
      "value": {
        "backdrop-filter": "blur(20px)",
        "background": "rgba(255, 255, 255, 0.68)",
        "border": "0.5px solid rgba(15, 23, 42, 0.06)",
        "box-shadow": "0 4px 8px rgba(15, 23, 42, 0.04), 0 16px 40px rgba(15, 23, 42, 0.06)",
        "fallback-background": "#FFFFFF",
        "fallback-border": "0.5px solid rgba(15, 23, 42, 0.08)"
      },
      "type": "other",
      "description": "Glass light · novo na v2.0.1. Uso sobre fundos claros (light mode, dentro de painel branco). Cenário majoritário do Patrimonium. Mesma regra-mãe de densidade de texto."
    }
  },

  "surface": {
    "light": {
      "page": {
        "value": {
          "background": "{color.neutral.surface}"
        },
        "type": "other",
        "description": "Camada 0 (light) · fundo da página/app shell."
      },
      "card": {
        "value": {
          "background": "{color.brand.white}",
          "box-shadow": "{shadow.1}"
        },
        "type": "other",
        "description": "Camada 1 (light) · cards, painéis principais."
      },
      "elevated": {
        "value": {
          "background": "{color.brand.white}",
          "box-shadow": "{shadow.3}"
        },
        "type": "other",
        "description": "Camada 2 (light) · modal, drawer, sheet, popover."
      }
    },
    "dark": {
      "shell": {
        "value": {
          "background": "{color.brand.navy-deep}"
        },
        "type": "other",
        "description": "Camada 0 (dark) · fundo da aplicação."
      },
      "painel": {
        "value": {
          "background": "{color.brand.blue}",
          "box-shadow": "{shadow.1}"
        },
        "type": "other",
        "description": "Camada 1 (dark) · cards, banners, painéis principais."
      },
      "elevated": {
        "value": {
          "background": "{color.brand.blue}",
          "border": "0.5px solid rgba(255, 255, 255, 0.08)",
          "box-shadow": "{shadow.3}"
        },
        "type": "other",
        "description": "Camada 2 (dark) · modal, drawer, sheet, popover."
      }
    }
  },

  "asset": {
    "logo": {
      "principal": {
        "value": "https://pablohpatrimonium.github.io/Patrimonium-DS/assets/logo-principal.png",
        "type": "other",
        "description": "Logo Patrimonium · versão positiva para fundos claros."
      },
      "negativa": {
        "value": "https://pablohpatrimonium.github.io/Patrimonium-DS/assets/logo-negativa.png",
        "type": "other",
        "description": "Logo Patrimonium · versão negativa para fundos escuros."
      }
    },
    "lockup": {
